#compdef worktree wt

# Zsh completion for git-worktree-manager plugin
# Provides autocomplete for worktree names

# Helper function to get list of worktree names
_get_worktrees() {
  local worktrees=()

  # Get worktree list and extract directory basenames
  if git worktree list --porcelain &>/dev/null; then
    worktrees=($(git worktree list --porcelain | \
      grep '^worktree ' | \
      awk '{print $2}' | \
      xargs -n1 basename))
  fi

  echo "${worktrees[@]}"
}

# Completion for the worktree command
_worktree() {
  local state

  _arguments \
    '1:subcommand:->subcommand' \
    '*::args:->args'

  case "$state" in
    subcommand)
      local subcommands
      subcommands=(
        'setup:Create a new worktree'
        'remove:Remove a worktree'
        'list:List all worktrees'
        'pull:Pull latest changes with stash/unstash'
        'dir:Initialize bare repo directory structure'
        'review:Review a GitHub PR in a new worktree'
        'tui:Open interactive TUI'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case "$line[1]" in
        remove)
          local worktrees
          worktrees=($(_get_worktrees))
          # Filter out "main" from the list
          worktrees=(${worktrees:#main})
          if [[ ${#worktrees[@]} -eq 0 ]]; then
            _message 'no removable worktrees found'
            return 1
          fi
          _arguments '1:worktree name:compadd -a worktrees'
          ;;
      esac
      ;;
  esac
}

# Completion for wt - includes all worktrees
_wt() {
  local worktrees
  worktrees=($(_get_worktrees))

  if [[ ${#worktrees[@]} -eq 0 ]]; then
    _message 'no worktrees found'
    return 1
  fi

  _arguments \
    '1:worktree name:compadd -a worktrees'
}

# Main completion dispatcher
_git_worktree_manager() {
  case "$service" in
    worktree)
      _worktree "$@"
      ;;
    wt)
      _wt "$@"
      ;;
  esac
}

# Execute the completion
_git_worktree_manager "$@"
