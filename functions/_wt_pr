# Review a PR by creating a worktree from the PR branch
function _wt_pr() {
  # Validate input
  if [[ -z "$1" ]]; then
    echo "❌ Error: GitHub PR URL required"
    echo "Usage: worktree review <github-pr-url>"
    echo ""
    echo "Example:"
    echo "  worktree review https://github.com/owner/repo/pull/123"
    return 1
  fi

  local pr_url="$1"

  # Check if gh CLI is installed
  if ! command -v gh &>/dev/null; then
    echo "❌ Error: GitHub CLI (gh) is not installed"
    echo "   Install it with: brew install gh"
    return 1
  fi

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 PR Review Setup"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Extract PR information using gh CLI
  echo "🔍 Fetching PR information..."
  local pr_data
  if ! pr_data=$(gh pr view "$pr_url" --json headRefName,number,title 2>&1); then
    echo "❌ Error: Failed to fetch PR information"
    echo "   $pr_data"
    echo ""
    echo "Make sure:"
    echo "  • The URL is correct"
    echo "  • You're authenticated with gh (run: gh auth login)"
    echo "  • You have access to the repository"
    return 1
  fi

  # Parse PR data
  local remote_branch_name=$(echo "$pr_data" | grep -o '"headRefName":"[^"]*"' | cut -d'"' -f4)
  local pr_number=$(echo "$pr_data" | grep -o '"number":[0-9]*' | cut -d':' -f2)
  local pr_title=$(echo "$pr_data" | grep -o '"title":"[^"]*"' | sed 's/"title":"//' | sed 's/"$//')

  if [[ -z "$remote_branch_name" ]]; then
    echo "❌ Error: Could not extract branch name from PR"
    return 1
  fi

  echo "✅ PR information retrieved"
  echo ""
  echo "   PR #$pr_number: $pr_title"
  echo "   Branch: $remote_branch_name"
  echo ""

  # Setup variables
  local local_branch_name="pr-$remote_branch_name"
  # Note: declare and assign separately so $? reflects the function, not 'local'
  local worktrees_dir
  worktrees_dir=$(_get_worktree_root)
  if [[ $? -ne 0 ]]; then
    echo "⚠️  Warning: Could not auto-detect worktree root"
    echo "Using current directory: $worktrees_dir"
  fi

  # Check if main worktree exists
  if [[ ! -d "$worktrees_dir/main" ]]; then
    echo "❌ Error: 'main' worktree not found in $worktrees_dir"
    echo "Please run this command from within a worktree directory structure"
    return 1
  fi

  # Check if worktree already exists
  if [[ -d "$worktrees_dir/$local_branch_name" ]]; then
    echo "❌ Error: Worktree '$local_branch_name' already exists at $worktrees_dir/$local_branch_name"
    echo "   Remove it first with: worktree remove $local_branch_name"
    return 1
  fi

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📂 Worktree root: $worktrees_dir"
  echo "🌿 Local branch: $local_branch_name"
  echo "🔗 Remote branch: origin/$remote_branch_name"
  echo "📂 Location: $worktrees_dir/$local_branch_name"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Fetch remote branch (subshell: CWD change is scoped)
  echo "⬇️  Fetching remote branch..."
  (
    cd "$worktrees_dir/main" || exit 1
    git fetch origin "$remote_branch_name"
  ) || {
    echo "❌ Error: Failed to fetch remote branch '$remote_branch_name'"
    return 1
  }
  echo "✅ Remote branch fetched"

  # Create worktree (subshell: CWD change is scoped)
  echo ""
  echo "🌳 Creating worktree..."
  # If a stale local branch exists from a previous review session, remove it so
  # git worktree add -b can create a fresh one tracking the latest remote state.
  if (cd "$worktrees_dir/main" && git show-ref --verify --quiet "refs/heads/$local_branch_name"); then
    echo "🔄 Removing stale local branch '$local_branch_name'..."
    (cd "$worktrees_dir/main" && git branch -D "$local_branch_name") || {
      echo "❌ Error: Failed to remove stale branch '$local_branch_name'"
      return 1
    }
  fi
  # Skip Husky hooks during worktree creation
  (cd "$worktrees_dir" && HUSKY_SKIP_HOOKS=1 git worktree add -b "$local_branch_name" "$local_branch_name" "origin/$remote_branch_name") || {
    echo "❌ Error: Failed to create worktree"
    return 1
  }
  echo "✅ Worktree created"

  # Set upstream tracking (subshell: CWD change is scoped)
  echo ""
  echo "🔗 Setting upstream tracking..."
  if (cd "$worktrees_dir/$local_branch_name" && git branch --set-upstream-to=origin/$remote_branch_name); then
    echo "✅ Upstream set to origin/$remote_branch_name"
  else
    echo "⚠️  Warning: Failed to set upstream tracking"
  fi

  # Copy config files (subshell: CWD changes are scoped)
  echo ""
  echo "📄 Copying configuration files..."
  local temp_tar="/tmp/pr_review_$$.tar"
  local file_count=0

  file_count=$(
    cd "$worktrees_dir/main" && \
    find . -type d -name node_modules -prune -o \
      \( -name '*.env' -o -name 'key.pem' -o -name 'cert.pem' \) \
      -type f -print | wc -l | tr -d ' '
  )

  if [[ "$file_count" -gt 0 ]]; then
    echo "   Found $file_count configuration file(s)"
    (
      cd "$worktrees_dir/main" && \
      find . -type d -name node_modules -prune -o \
        \( -name '*.env' -o -name 'key.pem' -o -name 'cert.pem' \) \
        -type f -print0 | tar -czf "$temp_tar" --null -T - 2>/dev/null
    )
    if (cd "$worktrees_dir/$local_branch_name" && tar -xzf "$temp_tar" 2>/dev/null); then
      echo "✅ Configuration files copied"
    else
      echo "⚠️  Warning: Some files may not have been copied"
    fi
    rm -f "$temp_tar"
  else
    echo "⚠️  No configuration files found"
  fi

  # Install dependencies (subshell: CWD change is scoped)
  # HUSKY_SKIP_INSTALL=true prevents Husky from overwriting shared .bare/hooks/
  # on every worktree creation, which would break hooks when the worktree is removed.
  echo ""
  echo "📦 Installing dependencies..."
  if (cd "$worktrees_dir/$local_branch_name" && HUSKY_SKIP_INSTALL=true yarn install); then
    echo "✅ Dependencies installed"
  else
    echo "❌ Warning: yarn install failed"
    echo "   You may need to run 'yarn install' manually"
  fi

  # Navigate to new worktree (intentional persistent cd)
  cd "$worktrees_dir/$local_branch_name" || return 1

  # Run Claude code review
  echo ""
  echo "🤖 Running Claude code review..."
  if command -v claude &>/dev/null; then
    claude --dangerously-skip-permissions "/code-review:code-review"
  else
    echo "⚠️  Warning: Claude CLI not installed, skipping code review"
    echo "   Install it from: https://docs.anthropic.com/en/docs/claude-code"
  fi

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🎉 PR Review worktree ready!"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 PR #$pr_number"
  echo "📂 Location: $(pwd)"
  echo "🌿 Branch: $(git branch --show-current)"
  echo "🔗 Tracking: origin/$remote_branch_name"
  echo ""
  echo "Next steps:"
  echo "  • Review the PR code! 🔍"
  echo "  • Run tests if needed"
  echo "  • Pull updates: git pull"
  echo "  • When done: worktree remove $local_branch_name"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}
